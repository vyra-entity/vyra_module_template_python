# =============================================================================
# VYRA Environment Configuration
# =============================================================================
# This file configures the VYRA module for different operating
# modes and service activations.
#
# Important modes:
# - Development: VYRA_DEV_MODE=true  → Vue Dev Server + Hot-Reload
# - Production:  VYRA_DEV_MODE=false → Nginx + optimized static files
# =============================================================================

# -----------------------------------------------------------------------------
# 🚀 Module Basic Configuration
# -----------------------------------------------------------------------------

# Module name - used for dynamic WSGI loading
# Important: Must match the actual module name!
MODULE_NAME={{ module_name }}

# -----------------------------------------------------------------------------
# 🐳 Docker Image Configuration
# -----------------------------------------------------------------------------

# Module-specific Docker image override (optional)
# If not set, uses VYRA_MODULE_IMAGE from reload script, which:
#   - Development (VYRA_DEV_MODE=true):  vyra_base_image:dev
#   - Production (VYRA_DEV_MODE=false):  ghcr.io/variobotic-gmbh/{{ module_name }}:latest
# 

# !! ONLY USE TO TEST PRODUCTIVE IMAGE LOCALLY FOR DEVELOPMENT !!
V2_MODULEMANAGER_IMAGE={{ module_name }}:production

# -----------------------------------------------------------------------------
# 🔧 Development Mode Settings
# -----------------------------------------------------------------------------

# Enable Development Mode
# true  = Vue.js Dev Server with Hot-Reload (Port 3000)
# false = Production mode with Nginx (Port 3000)
VYRA_DEV_MODE=true

# Set this to true to enable JSONL logging format for better 
# log parsing and integration with log management tools
# For development, it's often easier to read plain text logs, so default is false
VYRA_USE_JSONL_LOGS=false

# -----------------------------------------------------------------------------
# Architecture Mode Settings
# -----------------------------------------------------------------------------
# Startup Mode: Slim (pure Python|Rust) vs Normal (full with ROS2)
# true  = SLIM Mode: Pure Python|Rust execution without ROS2
#         - No ROS2 node, no gRPC services, no ROS2 communication
#         - TaskManager runs normally (application_runner, web_backend)
#         - ROS2-dependent tasks (ros_spinner, usermanager) are skipped
#         - Useful for: standalone applications, used for slim implementations
#         - Disk space: Minimal, no ROS2 installation required
#         - Log file: /workspace/log/core/core_stdout.log (always created)
#
# false = NORMAL Mode: Full ROS2 integration (default)
#         - ROS2 core initialized, gRPC services available
#         - All tasks run: application_runner, ros_spinner, usermanager, web_backend
#         - Full communication via ROS2 topics/services available
#         - Useful for: full-featured modules that require ROS2 capabilities
#         - Disk space: Requires ROS2 installation, larger image size
#         - Log files: /workspace/log/core/core_stdout.log + /workspace/log/ros2/* (ROS2 internal logs)

# Default: true
VYRA_SLIM=true

# Set this to true to enable Rust-based implementation of the module
# This is used to switch between Python and Rust implementations if both are available
# IMPORTANT: Ensure that the Rust implementation is properly set up and tested before enabling this.
#            Also it is important to set this to true if you have a rust implementation, otherwise the 
#            module will not start as it won't find the python implementation.
VYRA_RUST=false

# Hot Reload for automatic rebuild and restart
# true  = Watches src/ folder and rebuilds ROS2|Rust|Python packages on changes
# false = No automatic rebuild (manual colcon build required)
# Only used when VYRA_DEV_MODE=true
ENABLE_HOT_RELOAD=true

# -----------------------------------------------------------------------------
# 🔐 Internal Usermanager Configuration (Frontend)
# -----------------------------------------------------------------------------
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# 🌐 Service Activation (Supervisord-controlled)
# -----------------------------------------------------------------------------
# =============================================================================
# 📋 Service Overview by Configuration:
#
# VYRA_DEV_MODE=true (Development):
# ├── Frontend: Vue Dev Server (application.py managed)
# ├── Backend:  Gunicorn API (supervisord managed)
# └── ROS2:     Daemon for backend communication
#
# VYRA_DEV_MODE=false (Production):
# ├── Frontend: Nginx Static Files (supervisord managed)
# ├── Backend:  Gunicorn API (supervisord managed)
# └── ROS2:     Daemon for backend communication
#
# Ports:
# - Frontend: http://localhost:3000
# - Backend:  https://localhost:8443
# =============================================================================RCL_LOGGING_LOG_FILE_NAME=rust_test_ros2_core.log

# Frontend Web Server (Nginx)
# true  = Nginx starts automatically and serves static files
# false = Nginx remains disabled
# Note: Automatically disabled when VYRA_DEV_MODE=true
ENABLE_FRONTEND_WEBSERVER=true

# Backend API Server (Uvicorn/ASGI)
# true  = Uvicorn ASGI server starts automatically (Port 8443)
# false = Backend remains disabled
# Note: Should almost always be true as API is needed for Vue Dev Server
# Supports async operations via ASGI
ENABLE_BACKEND_WEBSERVER=true

# -----------------------------------------------------------------------------
# Additional environment variables can be added below as needed for your module.
# For example, database connection strings, API keys, etc.
# -----------------------------------------------------------------------------
RCL_LOGGING_LOG_FILE_NAME=ros2_core.log
