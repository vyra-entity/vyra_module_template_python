# build artifacts
build/*
install/*
package-lock.json
yarn.lock
*.msg
*.srv
*.action
*.proto
**/_gen/*.py
**/_gen/*.pyi
**/_gen/*.h
**/_gen/*.cpp

# Log files
log/*
*.log

# Automatic loaded interface files
**/*_interfaces/config/vyra_*.meta.json

# Frontend (build artifacts)
**/frontend/node_modules/*
**/frontend/dist/*

**/sros2_keystore/*
**/security/*

# SSL Certificates (sensitive data)
*.key
*.crt
*.pem
*.p7s
*/storage/interfaces/grpc_*/*

# Dynamically changing files
CMakeLists.txt
package.xml
*.launch.py
*.launch

# Exception: template source package.xml files must be tracked by git
# so that `copier copy --vcs-ref HEAD` includes them in generated modules
!src/*/package.xml
!src/*_interfaces/package.xml

# Temporary files
temp/*

# IDE specific files
.idea/*
.vscode/*

# dist files
dist/*


# OS generated files
*.tmp
*.bak

# Dynamically generated files
.env
!.env.example
*.pyc
*.sqlite
*.whl