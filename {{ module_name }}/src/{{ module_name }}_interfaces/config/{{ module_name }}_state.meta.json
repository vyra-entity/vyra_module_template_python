        ],
        "type": "action",
        "functionname": "request_lc_suspend",
        "displayname": "Request Lifecycle Suspend",
        "description": "Request a lifecycle suspend transition (ACTIVE -> SUSPENDED). Runs registered suspend callbacks with priorities before completing. Streams feedback during execution.",
