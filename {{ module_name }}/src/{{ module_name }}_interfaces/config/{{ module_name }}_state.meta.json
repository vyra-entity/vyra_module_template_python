            "VBASEStateRequestLcSuspend.proto"
        ],
        "params": [],
        "feedback": [
            {
                "name": "status",
                "datatype": "string",
                "displayname": "Status",
                "description": "Current status message during suspend execution"
            },
            {
                "name": "progress",
                "datatype": "int32",
                "displayname": "Progress",
                "description": "Progress percentage (0-100)"
            }
        ],
        "returns": [
            {
                "name": "success",
                "datatype": "bool",
                "displayname": "Success",
                "description": "Whether the suspend completed successfully"
            },
            {
                "name": "message",
                "datatype": "string",
                "displayname": "Message",
                "description": "Result message"
            },
            {
                "name": "final_state",
                "datatype": "string",
                "displayname": "Final State",
                "description": "The final lifecycle state after the action completed"
            }
        ],
        "access_level": 1,
