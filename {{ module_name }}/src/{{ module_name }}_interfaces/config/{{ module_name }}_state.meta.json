        ],
        "type": "service",
        "functionname": "get_state_history",
        "displayname": "Get State History",
        "description": "Returns recent state-change history entries, optionally filtered by layer and limited in count.",
        "filetype": [
            "VBASEState.proto"
        ],
        "params": [
            {
                "name": "limit",
                "datatype": "int",
                "displayname": "Limit",
                "description": "Maximum number of history entries to return (optional, default: all)."
            },
            {
                "name": "layer",
                "datatype": "string",
                "displayname": "Layer Filter",
                "description": "Filter by layer name: lifecycle, operational or health (optional)."
            }
        ],
        "returns": [
            {
                "name": "history",
                "datatype": "object[]",
                "displayname": "History",
                "description": "List of state-change entries (newest last)."
            },
            {
                "name": "count",
                "datatype": "int",
                "displayname": "Count",
                "description": "Number of entries returned."
            },
            {
                "name": "total",
                "datatype": "int",
                "displayname": "Total",
                "description": "Total entries in history buffer."
            },
            {
                "name": "success",
                "datatype": "bool",
                "displayname": "Success",
                "description": "True on successful call."
            }
        ],
        "access_level": 1,
        "displaystyle": {
            "visible": true,
            "published": true
        }
    },
    {
