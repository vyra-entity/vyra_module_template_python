        "type": "service",
        "functionname": "get_state",
        "displayname": "Get State",
        "description": "Returns the full 3-layer state snapshot (lifecycle, operational, health) with metadata.",
        "filetype": [
            "VBASEState.proto"
        ],
        "params": [],
        "returns": [
            {
                "name": "lifecycle",
                "datatype": "string",
                "displayname": "Lifecycle State",
                "description": "Current lifecycle state value (e.g. OFFLINE, INITIALIZING, ACTIVE)."
            },
            {
                "name": "operational",
                "datatype": "string",
                "displayname": "Operational State",
                "description": "Current operational state value (e.g. IDLE, READY, RUNNING)."
            },
            {
                "name": "health",
                "datatype": "string",
                "displayname": "Health State",
                "description": "Current health state value (e.g. HEALTHY, WARNING, FAULT)."
            },
            {
                "name": "timestamp",
                "datatype": "string",
                "displayname": "Timestamp",
                "description": "ISO 8601 timestamp of the snapshot."
            },
            {
                "name": "metadata",
                "datatype": "object",
                "displayname": "Metadata",
                "description": "Module name, UUID and derived flags (is_operational, is_healthy)."
            },
            {
                "name": "success",
                "datatype": "bool",
                "displayname": "Success",
                "description": "True on successful call."
            }
        ],
        "access_level": 1,
        "displaystyle": {
            "visible": true,
            "published": true
        }
